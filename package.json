  },
  "peerDependencies": {
    "react": ">=16.8"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.2.0",
    "playwright": "^1.60.0"
  },
  "keywords": [
    "react",
    "context-menu",
    "right-click",
    "menu",
    "popup",
    "ui"
